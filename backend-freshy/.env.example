# Copy this file to .env and fill in your Supabase credentials
# Never commit the real .env file — it contains secrets

# Supabase project URL  (Settings → API → Project URL)
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Service Role Key — keeps backend calls outside of RLS
# (Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini — get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional overrides
APP_NAME=Freshy API
APP_VERSION=0.1.0
DEBUG=false
